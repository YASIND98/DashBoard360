<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Yönetici Raporu</title>
    <link rel="stylesheet" href="~/css/site.css" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet" />
</head>
<body>
    <div class="app-wrapper">
        <!-- Sidebar -->
        <aside class="sidebar">
            <div class="sidebar-logo">
                <img src="~/images/denizbank-text-logo.svg" alt="DenizBank" class="sidebar-text-logo" />
                <img src="~/images/denizbank-logo.svg" alt="Logo" />
            </div>
            @{
                var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
            }
            <a href="/" class="sidebar-nav @(currentController == "Home" ? "active" : "")">
                <img src="~/images/homepage.svg" alt="Ana Sayfa" />
                <span class="sidebar-label">Hedef Raporları</span>
            </a>
            <a href="/verim-raporlari" class="sidebar-nav @(currentController == "YieldReports" ? "active" : "")">
                <img src="~/images/magic-star.svg" alt="Verim Raporları" />
                <span class="sidebar-label">Verim Performans</span>
            </a>
        </aside>

        <!-- Main Content -->
        <div class="main-content">
            @RenderBody()
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <link href="~/assets/lib/loadingjs/loading.css" rel="stylesheet" />
    <script src="~/assets/lib/loadingjs/loading.js"></script>
    <script src="~/js/site.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
