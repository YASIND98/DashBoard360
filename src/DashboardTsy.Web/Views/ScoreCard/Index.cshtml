@model ReportViewModel




<link rel="stylesheet" href="~/css/score-card.css" asp-append-version="true" />

<!-- Page Header -->
<div class="page-header sc-page-header">
<h1 class="page-title">Skor Kart</h1>
    <div class="page-date">
        <div class="sc-date-picker" id="scDatePicker">
            <button type="button" class="sc-dp-nav" id="scDpPrev">&#8249;</button>
            <div class="sc-dp-trigger-wrap">
                <button type="button" class="sc-dp-trigger" id="scDpTrigger">
                    <strong id="scDpLabel"></strong>
                    <span class="sc-dp-badge" id="scDpBadge"></span>
                    <img src="~/images/down.svg" alt="" class="sc-dp-arrow" />
                </button>
                <div class="sc-dp-panel" id="scDpPanel"></div>
            </div>
            <button type="button" class="sc-dp-nav" id="scDpNext">&#8250;</button>
        </div>
    </div>
    @await Html.PartialAsync("_AvatarArea")
</div>

<!-- Breadcrumb: Bölge / Şube / Sicil -->
<div class="breadcrumb-bar" id="scBreadcrumbBar" style="display:none;">
    <div class="breadcrumb" id="scBreadcrumb"></div>
</div>

<!-- Filters -->
<div class="filters-row">
    <div class="filters-left">
        <div class="filter-dropdown-wrapper">
            <div class="filter-dropdown" id="scRegionSelect">
                <span class="filter-label" id="scRegionLabel">Bölge</span>
                <img src="~/images/down.svg" alt="" />
            </div>
            <div class="dropdown-panel" id="scRegionPanel">
                <div class="dropdown-search">
                    <img src="~/images/search.svg" alt="" />
                    <input type="text" placeholder="Ara" class="dropdown-search-input" id="scRegionSearch" />
                </div>
                <div class="dropdown-list" id="scRegionList"></div>
            </div>
        </div>

        <div class="filter-dropdown-wrapper">
            <div class="filter-dropdown" id="scBranchSelect">
                <span class="filter-label" id="scBranchLabel">Şube</span>
                <img src="~/images/down.svg" alt="" />
            </div>
            <div class="dropdown-panel" id="scBranchPanel">
                <div class="dropdown-search">
                    <img src="~/images/search.svg" alt="" />
                    <input type="text" placeholder="Ara" class="dropdown-search-input" id="scBranchSearch" />
                </div>
                <div class="dropdown-list" id="scBranchList"></div>
            </div>
        </div>

        <div class="filter-dropdown-wrapper" id="scRegisterWrapper">
            <div class="filter-dropdown" id="scRegisterSelect">
                <span class="filter-label" id="scRegisterLabel">Sicil No</span>
                <img src="~/images/down.svg" alt="" />
            </div>
            <div class="dropdown-panel" id="scRegisterPanel">
                <div class="dropdown-search">
                    <img src="~/images/search.svg" alt="" />
                    <input type="text" placeholder="Ara" class="dropdown-search-input" id="scRegisterSearch" />
                </div>
                <div class="dropdown-list" id="scRegisterList"></div>
            </div>
        </div>

        <div class="filter-search">
            <img src="~/images/search.svg" alt="" />
            <input type="text" placeholder="Ara" id="scSearchInput" />
        </div>
    </div>

    <!-- Pupa tipi segmentleri sales-target-monitoring/pupa-types servisinden gelir (renderPupaChannels) -->
    <div class="segmented-control" id="scChannels"></div>
</div>

<!-- Tabs + Period -->
<div class="tab-bar">
    <!-- Skor kart sekmeleri dashboard/score-cards servisinden gelir (renderScoreCardTabs) -->
    <div class="tab-list" id="scTabList"></div>
    <div class="period-toggle" id="scPeriod">
        <button class="period-btn active" data-period="aylik">
            <img src="~/images/calendar.svg" alt="monthly" class="period-icon" /> Aylık
        </button>
        <button class="period-btn" data-period="ceyreklik">
            <img src="~/images/quarterly-calendar.svg" alt="" class="period-icon" /> Çeyreklik
        </button>
        <button class="period-btn" data-period="yillik">
            <img src="~/images/yearly-calendar.svg" alt="" class="period-icon" /> Yıllık
        </button>
    </div>
</div>

<!-- Banka/Bölge sıralaması (dashboard/employee-order-summaries) yalnızca şube seçiliyken gösterilir-->
<div class="sc-ranking-bar" style="display:none;">
    <div class="sc-ranking-card">
        <span class="sc-ranking-label">Banka Sıralaması
            <img src="~/images/info.svg" alt="" class="sc-ranking-info" data-tooltip="Bankada ilgili skorkart tipi arasındaki sıralama" />
        </span>
        <div class="sc-ranking-value"><strong class="first-number" id="scBankRank"></strong><span class="second-number" id="scBankRankTotal"></span></div>
    </div>
    <div class="sc-ranking-card">
        <span class="sc-ranking-label">Bölge Sıralaması
            <img src="~/images/info.svg" alt="" class="sc-ranking-info" data-tooltip="Bölgede ilgili skorkart tipi arasındaki sıralama" />
        </span>
        <div class="sc-ranking-value"><strong class="first-number" id="scRegionRank"></strong><span class="second-number" id="scRegionRankTotal"></span></div>
    </div>
    <div class="sc-ranking-card">
        <span class="sc-ranking-label">Toplam Skor
            <img src="~/images/info.svg" alt="" class="sc-ranking-info" data-tooltip="Toplam ağırlıklı H/G bilgisidir." />
        </span>
        <div class="sc-ranking-value"><strong class="first-number" id="scTotalScore"></strong><span class="second-number" id="scTotalScoreMax">/100</span></div>
    </div>
</div>

<!-- Skor kart grubu (ör. Bireysel) seçilince alt sekmeler -->
<div class="sub-tab-bar" id="scSubTabBar" style="display:none;">
    <div class="tab-list" id="scSubTabList"></div>
</div>

<!-- Score Card Report Table Skeleton (servis isteği sırasında; hedef raporlarındaki gibi) -->
<div id="scTableSkeleton" class="page-skeleton" style="display:none;">
    <div class="skeleton-table">
        @for (int i = 0; i < 8; i++)
        {
            <div class="skeleton-table-row">
                <div class="skeleton-bar" style="width:24px;height:24px"></div>
                <div class="skeleton-bar" style="width:22%;height:16px"></div>
                <div class="skeleton-bar" style="width:10%;height:16px"></div>
                <div class="skeleton-bar" style="width:10%;height:16px"></div>
                <div class="skeleton-bar" style="width:10%;height:16px"></div>
                <div class="skeleton-bar" style="width:8%;height:16px"></div>
                <div class="skeleton-bar" style="width:8%;height:16px"></div>
                <div class="skeleton-bar" style="width:10%;height:16px"></div>
                <div class="skeleton-bar" style="width:8%;height:16px"></div>
                <div class="skeleton-bar" style="width:24px;height:24px"></div>
            </div>
        }
    </div>
</div>

<!-- Score Card Report Table -->
<div class="table-container" id="scTableContainer">
    <div class="table-wrapper">
        <table class="data-table">
            <thead id="scReportHead"></thead>
            <tbody id="scReportBody"></tbody>
        </table>
    </div>
    <div class="table-legend" id="scReportLegend"></div>
</div>

<!-- Skor Kart Detay Modal (satırdaki Detay ikonundan açılır) -->
<div class="sc-overlay" id="scOverlay" role="dialog" aria-modal="true" aria-labelledby="scModalTitle">
    <div class="sc-modal">

        <div class="sc-header">
          <img id="scClose" src="~/images/close-circle.svg" alt="close" />
          <span class="sc-title" id="scModalTitle">Aktif Kredi Kartı Performansı</span>
          <div class="download-pdf-btn" id="scTrendPdfBtn" data-pdf="scTrend" style="margin-left:auto; display:none;">
              <img src="~/images/download.svg" alt="" />
              <span>PDF İndir</span>
          </div>
        </div>

        <div class="sc-tabs" id="scTabs">
            <button type="button" class="sc-tab active" data-tab="hedef">Hedef Detayı</button>
            <button type="button" class="sc-tab" data-tab="trend">Trend Analizi</button>
        </div>

        <!-- Hedef Detayı Tabı -->
        <div class="sc-target-detail" id="scTargetDetail">
          <div class="sc-filters" id="scFilters">
              <button type="button" class="sc-filter active" data-filter="realized">
                  <img class="sc-filter-icon" src="~/images/realized.svg" alt="" />
                  <span>Gerçekleşen</span>
              </button>
              <button type="button" class="sc-filter" data-filter="pending">
                  <img class="sc-filter-icon" src="~/images/pending.svg" alt="" />
                  <span>Bekleyen</span>
              </button>
              <button type="button" class="sc-filter" data-filter="unrealized">
                  <img class="sc-filter-icon" src="~/images/unrealized.svg" alt="" />
                  <span>Gerçekleşmeyen</span>
              </button>
          </div>

          <div class="sc-table-wrapper" id="scTableSection">
              <table class="sc-table">
                  <thead id="scTableHead"></thead>
                  <tbody id="scTableBody"></tbody>
              </table>
          </div>

          <div class="sc-footer">
              <div class="download-pdf-btn" id="scDetailPdfBtn" data-pdf="scDetail" style="margin-right:auto;">
                  <img src="~/images/download.svg" alt="" />
                  <span>PDF İndir</span>
              </div>
              <div class="sc-pagination" id="scPagination"></div>
          </div>
        </div>

        <!-- Trend Analizi Tabı -->
        <div class="sc-trend" id="scTrend" style="display: none;">
            <div class="sc-trend-tabs" id="scTrendTabs">
                <button type="button" class="sc-trend-tab active" data-trend-period="bu-ay">Bu Ay</button>
                <button type="button" class="sc-trend-tab" data-trend-period="son-3-ay">Son 3 Ay</button>
                <button type="button" class="sc-trend-tab" data-trend-period="son-6-ay">Son 6 Ay</button>
                <button type="button" class="sc-trend-tab" data-trend-period="son-12-ay">Son 12 Ay</button>
            </div>
            <div id="scTrendChart"></div>
        </div>

    </div>
</div>

@section Scripts {
    @{
        var sessionUser = System.Text.Json.JsonSerializer.Deserialize<DashboardTsy.Web.Models.UsersDto>(
            Context.Session.GetString("User") ?? "null");
        var dashboardApiOptions = Context.RequestServices
            .GetRequiredService<Microsoft.Extensions.Options.IOptions<DashboardTsy.Web.Services.DashboardApiOptions>>().Value;
        var scoreCardProxyBase = (dashboardApiOptions.BaseUrl?.TrimEnd('/') ?? "") + "/scorecard";
    }
    <script>
        // Skor kart servislerine userCode olarak gönderilir (session User.DomainName).
        window.USER_CODE = @Html.Raw(Json.Serialize(sessionUser?.DomainName));
        // Skor kart proxy URL'i: DashboardTsy.Api üzerinden Pupa servislerine iletilir.
        window.SCORE_CARD_BASE_URL = @Html.Raw(Json.Serialize(scoreCardProxyBase));
    </script>
    <script src="~/assets/lib/html2canvas/html2canvas.min.js" asp-append-version="true"></script>
    <script src="~/assets/lib/jspdf/jspdf.umd.min.js" asp-append-version="true"></script>
    <script src="~/js/download-pdf.js" asp-append-version="true"></script>
    <script src="~/js/shared/mock.js" asp-append-version="true"></script>
    <script src="~/js/score-card/index.js" asp-append-version="true"></script>
    <script src="~/js/score-card/date-picker.js" asp-append-version="true"></script>
    <script src="~/js/score-card/filters.js" asp-append-version="true"></script>
    <script src="~/js/score-card/target-detail.js" asp-append-version="true"></script>
    <script src="~/js/score-card/trend-analize.js" asp-append-version="true"></script>
}
